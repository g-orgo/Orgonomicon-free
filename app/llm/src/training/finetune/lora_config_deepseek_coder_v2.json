{
  "schema": "orgonomicon.finetune.lora.v2",
  "base_model": "deepseek-ai/deepseek-coder-v2-lite-instruct",
  "output_dir": "llm/training/finetune/adapters/deepseek-coder-v2-lora",
  "dataset_path": "llm/training/finetune/data/deepseek_coder_sft.jsonl",
  "startup_finetune": {
    "enabled": true,
    "allow_in_production": false,
    "run_training": true,
    "skip_if_missing_dependencies": true,
    "max_new_rows_per_startup": 8,
    "datasets_dir": "llm/training/datasets",
    "delta_dataset_path": "llm/training/finetune/data/startup_delta_sft.jsonl",
    "state_path": "llm/training/finetune/state/taught_ids.json"
  },
  "text_column": "text",
  "max_seq_length": 1024,
  "train_test_split": 0.05,
  "quantization": {
    "enabled": true,
    "bits": 4,
    "quant_type": "nf4",
    "compute_dtype": "float16",
    "double_quant": true,
    "use_4bit": true
  },
  "training": {
    "num_train_epochs": 2,
    "max_steps": -1,
    "per_device_train_batch_size": 1,
    "gradient_accumulation_steps": 16,
    "learning_rate": 2e-4,
    "lr_scheduler_type": "cosine",
    "logging_steps": 5,
    "save_steps": 50,
    "warmup_steps": 20,
    "fp16": true,
    "bf16": false,
    "gradient_checkpointing": true,
    "optim": "paged_adamw_8bit",
    "max_grad_norm": 1.0,
    "weight_decay": 0.01,
    "save_total_limit": 3,
    "report_to": [],
    "disable_tqdm": true
  },
  "lora": {
    "r": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.05,
    "bias": "none",
    "task_type": "CAUSAL_LM",
    "target_modules": [
      "q_proj",
      "v_proj",
      "o_proj"
    ]
  }
}
